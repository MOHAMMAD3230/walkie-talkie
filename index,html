 <script>
    // ===== STATE MANAGEMENT =====
    let matrixActive = false;
    let hudActive = true;

    // ===== MATRIX ANIMATION =====
    const canvas = document.getElementById('matrix');
    const ctx = canvas.getContext('2d');
    
    function resizeCanvas() { 
        canvas.width = window.innerWidth; 
        canvas.height = window.innerHeight; 
    }
    resizeCanvas();
    
    const characters = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ1234567890@#$%^&*()+~{}[]<>?';
    const fontSize = 20;
    let columns = Math.floor(canvas.width / fontSize);
    const drops = new Array(columns).fill(0);
    let currentBg = { r: 0, g: 0, b: 16 };

    function toggleMatrix() {
        matrixActive = !matrixActive;
        const lever = document.getElementById('lever-matrix');
        
        if (matrixActive) {
            lever.classList.add('active');
        } else {
            lever.classList.remove('active');
            // Clear canvas immediately when turning off
            ctx.fillStyle = '#000010';
            ctx.fillRect(0, 0, canvas.width, canvas.height);
        }
    }

    function drawMatrix() {
        // Fade effect for trails
        ctx.fillStyle = `rgba(${currentBg.r}, ${currentBg.g}, ${currentBg.b}, 0.1)`;
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        ctx.font = fontSize + 'px monospace';
        
        if (matrixActive) {
            for (let i = 0; i < drops.length; i++) {
                const text = characters.charAt(Math.floor(Math.random() * characters.length));
                const colorShift = currentBg.r > 20 ? '#ff5555' : (i % 2 === 0 ? '#00bfff' : '#e0f7ff');
                ctx.fillStyle = colorShift;
                ctx.fillText(text, i * fontSize, drops[i] * fontSize);
                if (drops[i] * fontSize > canvas.height && Math.random() > 0.975) drops[i] = 0;
                drops[i]++;
            }
        }
    }
    
    setInterval(drawMatrix, 50);
    
    window.addEventListener('resize', () => { 
        resizeCanvas(); 
        columns = Math.floor(canvas.width / fontSize); 
        drops.length = columns; 
        drops.fill(0); 
    });

    // ===== SECURITY LEVER (HUD TOGGLE) =====
    function toggleHUD() {
        hudActive = !hudActive;
        const lever = document.getElementById('lever-security');
        const hudElements = document.querySelectorAll('.hud-element');
        
        if (hudActive) {
            lever.classList.add('active');
            hudElements.forEach(el => el.classList.remove('hud-hidden'));
        } else {
            lever.classList.remove('active');
            hudElements.forEach(el => el.classList.add('hud-hidden'));
        }
    }

    // ===== UI HELPERS =====
    function toggleCategoryPanel() {
        document.getElementById('categoriesPanel').classList.toggle('expanded');
        document.getElementById('categoryDropdown').classList.toggle('show');
    }

    function toggleSubmenu(event) {
        event.preventDefault();
        const mainCategory = event.target.closest(".main-category");
        if (!mainCategory) return;
        const submenu = mainCategory.querySelector(".submenu");
        if (!submenu) return;
        submenu.style.display = submenu.style.display === "none" ? "block" : "none";
    }

    function filterCategories() {
        const filter = document.getElementById("categoryFilter").value.toUpperCase();
        const links = document.getElementById("categoryDropdown").querySelectorAll("a");
        links.forEach(el => {
            const txt = el.textContent || el.innerText;
            el.style.display = txt.toUpperCase().indexOf(filter) > -1 ? "" : "none";
        });
    }

    function toggleDeckExpand() {
        document.getElementById('systemPanel').classList.toggle('expanded');
    }

    let isPoweredOn = true;
    function togglePower(event) {
        event.stopPropagation();
        isPoweredOn = !isPoweredOn;
        const btn = document.getElementById('powerBtn');
        const content = document.getElementById('deckContent');

        if (isPoweredOn) {
            btn.innerText = "PWR: ON";
            btn.classList.add('on');
            content.style.opacity = "1";
            content.style.pointerEvents = "auto";
            addTerminalLog("SYSTEM COLD BOOT SUCCESSFUL", "#00f0ff");
        } else {
            btn.innerText = "PWR: OFF";
            btn.classList.remove('on');
            content.style.opacity = "0.1";
            content.style.pointerEvents = "none";
            document.getElementById('downMB').innerText = "0";
            document.getElementById('upMB').innerText = "0";
            document.getElementById('lossVal').innerText = "0.00%";
            document.getElementById('threatVal').innerText = "0%";
            document.getElementById('threatBar').style.width = "0%";
            document.getElementById('decryptVal').innerText = "0%";
            document.getElementById('decryptBar').style.width = "0%";
        }
    }

    // ===== CYBER DECK LOGIC =====
    let startTime = Date.now();
    let graphPoints = [35, 30, 32, 28, 35, 30, 25, 30, 35, 38, 40];
    let decryptPercent = 0;
    let isMuted = false;
    let lastBreachStatus = false;
    let breachCount = 0;
    let autoResponse = false;
    let isLockdown = false;
    let tracePercent = 0;
    
    const deckLogs = ["Decrypting block...", "RSA Key Found", "Bypassing Firewall", "Node link: Active", "Shifting Frequency"];

    function updateDashboard() {
        if (isLockdown) return;

        const now = new Date();
        document.getElementById('digitalClock').innerText = now.toLocaleTimeString('en-GB');

        if (!isPoweredOn) return; 
        
        let diff = Math.floor((Date.now() - startTime) / 1000) + 87200;
        document.getElementById('uptimeVar').innerText = `${Math.floor(diff/86400).toString().padStart(2,'0')}:${Math.floor((diff%86400)/3600).toString().padStart(2,'0')}:${Math.floor((diff%3600)/60).toString().padStart(2,'0')}:${(diff%60).toString().padStart(2,'0')}`;

        let dl = (Math.random() * 45 + 10).toFixed(1);
        let ul = (Math.random() * 15 + 2).toFixed(1);
        let lossNum = (Math.random() > 0.92) ? (Math.random() * 0.15) : (Math.random() * 0.01);
        
        if (autoResponse && lossNum > 0.05) {
            lossNum = 0.00;
            addTerminalLog("AUTO-RESPONSE: Threat neutralized", "#00ff88");
        }

        const isBreach = lossNum > 0.05;
        const color = isBreach ? "#ff4444" : "#00f0ff";

        if (isBreach) {
            tracePercent += 2.5; 
            breachCount++;
            document.getElementById('breachCount').innerText = breachCount;
            if (!lastBreachStatus) {
                if (!isMuted) document.getElementById('alertSound').play().catch(()=>{});
                addTerminalLog("BREACH_DETECTED", "#ff4444");
            }
        } else if (tracePercent > 0) {
            tracePercent -= 0.5;
        }

        tracePercent = Math.max(0, Math.min(100, tracePercent));

        if (tracePercent >= 100) {
            isLockdown = true;
            addTerminalLog("SYSTEM LOCKDOWN: TRACE COMPLETE", "#ff0000");
            document.body.style.filter = "grayscale(1) contrast(2) invert(1)";
            return;
        }

        lastBreachStatus = isBreach;
        document.getElementById('statusLabel').innerText = isBreach ? "STATUS: BREACH" : "STATUS: SECURE";
        document.getElementById('statusLabel').style.color = color;
        document.getElementById('pulseNode').style.backgroundColor = color;
        document.getElementById('downMB').innerText = dl;
        document.getElementById('upMB').innerText = ul;
        document.getElementById('lossVal').innerText = lossNum.toFixed(2) + "%";

        if (decryptPercent < 99.9) decryptPercent += Math.random() * 0.5;
        else if (Math.random() > 0.98) decryptPercent = 0;
        document.getElementById('decryptVal').innerText = decryptPercent.toFixed(1) + "%";
        document.getElementById('decryptBar').style.width = decryptPercent + "%";

        let threatLevel = Math.min(100, (lossNum * 2000) + (decryptPercent * 0.4));
        document.getElementById('threatVal').innerText = threatLevel.toFixed(0) + '%';
        document.getElementById('threatBar').style.width = threatLevel + '%';
        document.getElementById('threatBar').style.boxShadow = `0 0 8px hsl(${120 - threatLevel}, 100%, 50%)`;

        if (threatLevel > 80) {
            currentBg = { r: 40, g: 0, b: 0 };
            document.getElementById('systemPanel').style.boxShadow = "0 0 40px rgba(255, 0, 0, 0.6)";
        } else {
            currentBg = { r: 0, g: 0, b: 16 };
            document.getElementById('systemPanel').style.boxShadow = "0 0 25px rgba(255, 165, 0, 0.5)";
        }

        graphPoints.shift(); 
        graphPoints.push(Math.floor(Math.random() * 30 + 5));
        document.getElementById('graphLine').setAttribute("points", graphPoints.map((p, i) => `${i * 20},${p}`).join(" "));
        
        if (Math.random() > 0.85) addTerminalLog(deckLogs[Math.floor(Math.random() * deckLogs.length)], "#ffa500");
    }

    function addTerminalLog(msg, color) {
        const t = document.getElementById('terminalLog');
        if(!t) return;
        const entry = document.createElement('div');
        entry.style.color = color;
        entry.textContent = "> " + msg;
        t.prepend(entry);
        if (t.childNodes.length > 5) t.removeChild(t.lastElementChild);
    }

    function toggleMute() {
        isMuted = !isMuted;
        document.getElementById('muteBtn').innerText = isMuted ? "🔇" : "🔊";
    }

    function toggleAutoResponse() {
        autoResponse = !autoResponse;
        const btn = document.getElementById('autoResponse');
        btn.innerText = `AUTO: ${autoResponse ? 'ON' : 'OFF'}`;
        btn.style.color = autoResponse ? '#00ff88' : '#8888ff';
    }

    const deckHeader = document.querySelector('.bottom-right-panel h5');
    deckHeader.addEventListener('contextmenu', (e) => {
        e.preventDefault();
        breachCount = 0;
        decryptPercent = 0;
        tracePercent = 0;
        isLockdown = false;
        document.body.style.filter = "none";
        document.getElementById('breachCount').innerText = "0";
        document.getElementById('terminalLog').innerHTML = "";
        addTerminalLog("SYSTEM_PURGE: SUCCESSFUL", "#00f0ff");
    });

    setInterval(updateDashboard, 1000);
</script>

</body>
</html>
